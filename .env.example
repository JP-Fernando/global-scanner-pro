# ========================================
# Global Quant Scanner Pro - Configuration
# ========================================

# ----------------------------------------
# Server Configuration
# ----------------------------------------
PORT=3000
NODE_ENV=development
# Options: development, staging, production

# ----------------------------------------
# Security
# ----------------------------------------
# Set to 'true' only when this process runs behind a TLS-terminating reverse
# proxy (nginx, Caddy, a load balancer). Enables the HTTPS redirect + HSTS
# header. Leave 'false' for a bare `npm start` / `node dist/server.js` on
# localhost — there's no HTTPS listener to redirect to.
FORCE_HTTPS=false

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Session secret (generate with: openssl rand -base64 32)
SESSION_SECRET=your-session-secret-here-change-this-in-production

# Rate limiting
# RATE_LIMIT_MAX_REQUESTS / RATE_LIMIT_YAHOO_MAX default to relaxed values
# (5000 / 500) when NODE_ENV=development, and (2000 / 300) in staging/
# production — high enough that a full market scan (up to ~100 tickers) or
# an "ALL MARKETS" scan (~1200 tickers) doesn't get self-rate-limited.
# Uncomment below to override either environment.
RATE_LIMIT_WINDOW_MS=900000
# 15 minutes in milliseconds

# RATE_LIMIT_MAX_REQUESTS=2000
# Maximum requests per window per IP (production default: 2000)

# RATE_LIMIT_YAHOO_MAX=300
# Maximum Yahoo Finance API requests per minute (production default: 300)

# ----------------------------------------
# External Services
# ----------------------------------------
# SMTP Configuration for alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
# For Gmail, use App Password: https://support.google.com/accounts/answer/185833

# Webhook URLs for notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/YOUR/WEBHOOK/URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK/URL

# ----------------------------------------
# Monitoring and Error Tracking
# ----------------------------------------
# Sentry DSN for error tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development
# Options: development, staging, production

SENTRY_TRACES_SAMPLE_RATE=0.1
# Percentage of transactions to trace (0.0 - 1.0)

# ----------------------------------------
# Feature Flags
# ----------------------------------------
ENABLE_ML_FEATURES=true
ENABLE_ALERTS=true
ENABLE_PORTFOLIO_OPTIMIZER=true
ENABLE_STRESS_TESTING=true
ENABLE_ATTRIBUTION_ANALYSIS=true

# ----------------------------------------
# Redis Cache (optional — enables horizontal scaling)
# ----------------------------------------
# When set, the application uses Redis as a shared cache instead of the
# in-process node-cache, enabling multiple instances to share state.
# Format: redis://[:password@]host[:port][/db-number]
#         rediss://... for TLS (Redis Cloud, AWS ElastiCache, etc.)
# REDIS_URL=redis://localhost:6379
# REDIS_KEY_PREFIX=gsp:
# REDIS_CONNECT_TIMEOUT_MS=5000

# ----------------------------------------
# Authentication (JWT + SQLite user database)
# ----------------------------------------
# JWT signing secret (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-here-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Path to the SQLite database file (auto-created on first run)
DATABASE_PATH=./data/app.db

# Public base URL, used to build password-reset links
APP_URL=http://localhost:3000

# ----------------------------------------
# Database (Future use — server-side Postgres, not yet implemented)
# ----------------------------------------
# DATABASE_URL=postgresql://user:password@localhost:5432/scanner_db

# ----------------------------------------
# API Keys (Future integrations)
# ----------------------------------------
# ALPHA_VANTAGE_API_KEY=your-api-key
# FINNHUB_API_KEY=your-api-key
# POLYGON_API_KEY=your-api-key

# ----------------------------------------
# Logging
# ----------------------------------------
LOG_LEVEL=info
# Options: error, warn, info, http, verbose, debug, silly

LOG_FILE_PATH=./logs
# Path to store log files

LOG_MAX_FILES=7
# Number of log files to keep (legacy, kept for compatibility)

LOG_MAX_DAYS=14
# Days of combined/error logs to retain (daily rotation)

LOG_ZIP_ARCHIVED=true
# Compress rotated log files with gzip

# ----------------------------------------
# Performance
# ----------------------------------------
# Cache TTL in seconds
CACHE_TTL=300
# 5 minutes

# Maximum concurrent API requests
MAX_CONCURRENT_REQUESTS=10

# Request timeout in milliseconds
REQUEST_TIMEOUT=30000
# 30 seconds

# ----------------------------------------
# Development
# ----------------------------------------
# Enable debug mode
DEBUG=false

# Enable API documentation (Swagger)
ENABLE_API_DOCS=true
